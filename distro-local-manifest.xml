<?xml version="1.0" encoding="UTF-8"?>

<!--

repo local manifest use is outside of version control, a template is copied to .repo/local_manifests and then
modified to pickup the desired branch or commit-id by modifying the template using the sed command. after the
local manifest is prepared, it is necessary to perform repo sync again.

mkdir -p .repo/local_manifests
cp -f distro-local-manifest.xml .repo/local_manifests/distro-local-manifest.xml
sed -i -e 's/revision="BRANCH"/revision="branch_or_commit-id"/g' .repo/local_manifests/distro-local-manifest.xml
sed -i -e 's/upstream="BRANCH"/upstream="branch"/g' .repo/local_manifests/distro-local-manifest.xml
sed -i -e 's/dest-branch="BRANCH"/dest-branch="branch"/g' .repo/local_manifests/distro-local-manifest.xml
repo sync

-->

<manifest>

    <extend-project
        name="meta-distro"
        revision="BRANCH"
        upstream="BRANCH"
        dest-branch="BRANCH"
    />

</manifest>
